From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: lordofpipes <lordpipe@protonmail.com>
Date: Sun, 30 Nov 2025 11:29:47 -0700
Subject: [PATCH] Upgrade asymmetric encryption key size


diff --git a/net/minecraft/util/Crypt.java b/net/minecraft/util/Crypt.java
index e76431d60db9d39e93dc51fdc07b0b1e6c06be21..58a4292f66755728b26efbed0899451d643157f3 100644
--- a/net/minecraft/util/Crypt.java
+++ b/net/minecraft/util/Crypt.java
@@ -29,7 +29,7 @@ public class Crypt {
     private static final String SYMMETRIC_ALGORITHM = "AES";
     private static final int SYMMETRIC_BITS = 128;
     private static final String ASYMMETRIC_ALGORITHM = "RSA";
-    private static final int ASYMMETRIC_BITS = 1024;
+    private static final int ASYMMETRIC_BITS = 4096;
     private static final String BYTE_ENCODING = "ISO_8859_1";
     private static final String HASH_ALGORITHM = "SHA-1";
     public static final String SIGNING_ALGORITHM = "SHA256withRSA";
@@ -68,7 +68,7 @@ public class Crypt {
     public static KeyPair generateKeyPair() throws CryptException {
         try {
             KeyPairGenerator generator = KeyPairGenerator.getInstance("RSA");
-            generator.initialize(1024);
+            generator.initialize(4096);
             return generator.generateKeyPair();
         } catch (Exception e) {
             throw new CryptException(e);
